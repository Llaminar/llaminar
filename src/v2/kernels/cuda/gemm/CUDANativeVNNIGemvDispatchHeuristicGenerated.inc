inline __host__ void selectGeneratedDispatch_(
    int N, int K,
    NativeGemvShape& out_shape, GeneratedDispatchTuning& out_tuning)
{
    const float log2_n = log2f(static_cast<float>(N > 0 ? N : 1));
    const float log2_k = log2f(static_cast<float>(K > 0 ? K : 1));

    if constexpr (CB == 17)
    {
        selectTuning_CB17(log2_n, log2_k, out_shape, out_tuning);
    }
    else if constexpr (CB == 16)
    {
        selectTuning_CB16(log2_n, log2_k, out_shape, out_tuning);
    }
    else if constexpr (CB == 13)
