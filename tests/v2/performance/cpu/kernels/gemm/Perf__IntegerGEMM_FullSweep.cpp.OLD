/**
 * @file Perf__IntegerGEMM_FullSweep.cpp
 * @brief Complete configuration space sweep for Integer GEMM autotuner data collection
 *
 * This test systematically explores the full parameter space to gather training data
 * for an ML-based or heuristic-based kernel selection autotuner.
 *
 * Test Modes:
 * - AllConfigsAllWorkloads: Full sweep (all configs × all workloads) → ~104,000 configs
 * - AllConfigsSingleToken: Full sweep on M=1 decode workload → ~8,600 configs  
 * - SingleConfig_M*_N*_K*_MR*_...: Run specific config (for perf profiling)
 *
 * Output Format: CSV with columns:
 *   m,n,k,mr,nr,k_blocks,unroll_k,prefetch_dist,mc,kc,nc,gflops,time_ms,efficiency_pct
 *
 * Usage:
 *   # Full sweep (2-4 hours)
 *   ./v2_perf_integer_gemm_full_sweep --gtest_filter="*AllConfigsAllWorkloads"
 *
 *   # Single workload (30-60 minutes)
 *   ./v2_perf_integer_gemm_full_sweep --gtest_filter="*AllConfigsSingleToken"
 *
 *   # Specific config (for perf profiling)
 *   ./v2_perf_integer_gemm_full_sweep --gtest_filter="*SingleConfig_M512_N896_K896_MR8_NR32_KB4_U4_P2_MC256_KC512_NC128"
 *
 * @author David Sanftenberg
 * @date November 12, 2025
 */

#include <gtest/gtest.h>
#include <chrono>
#include <memory>
#include <vector>
#include <iostream>
#include <iomanip>
#include <fstream>
#include <random>
#include <cmath>
#include <string>
#include <sstream>

#include "kernels/cpu/gemm/int8/IntegerGemmKernelRegistry.h"
#include "kernels/cpu/gemm/GemmWeightCache.h"
#include "tensors/Tensors.h"
#include "tensors/BlockStructures.h"

using namespace llaminar2;
using namespace llaminar2::kernels;
using namespace llaminar2::kernels::gemm;

// ============================================================================
// Configuration Space for Autotuner Training
// ============================================================================

// Complete parameter space
const std::vector<int> MR_VALUES = {4, 8, 16, 32};
const std::vector<int> NR_VALUES = {32}; // Fixed for Q8_0 alignment
const std::vector<int> K_BLOCKS_VALUES = {2, 4}; // 64-byte and 128-byte
const std::vector<int> UNROLL_K_VALUES = {1, 2, 4, 8};
const std::vector<int> PREFETCH_DIST_VALUES = {0, 1, 2, 3};

// Cache blocking parameters (exploring reasonable ranges)
const std::vector<int> MC_VALUES = {128, 256, 512};
const std::vector<int> KC_VALUES = {256, 512, 1024};
const std::vector<int> NC_VALUES = {64, 128, 256};

// Fixed parameters
using ISA = AVX512VNNITag;
constexpr double THEORETICAL_PEAK_GFLOPS = 358.4; // Conservative INT8 estimate

// ============================================================================
// Test Workloads (Qwen 0.5B operations)
// ============================================================================

struct OpDescriptor {
    std::string name;
    int m, n, k;
};

const std::vector<OpDescriptor> ALL_WORKLOADS = {
    // Decode (single token) - latency critical
    {"Q_proj_decode", 1, 896, 896},
    {"FFN_gate_decode", 1, 4864, 896},
    {"FFN_down_decode", 1, 896, 4864},
    
    // Prefill batch=32
    {"Q_proj_prefill32", 32, 896, 896},
    {"FFN_gate_prefill32", 32, 4864, 896},
    {"FFN_down_prefill32", 32, 896, 4864},
    
    // Prefill batch=128
    {"Q_proj_prefill128", 128, 896, 896},
    {"FFN_gate_prefill128", 128, 4864, 896},
    {"FFN_down_prefill128", 128, 896, 4864},
    
    // Prefill batch=512 (max throughput)
    {"Q_proj_prefill512", 512, 896, 896},
    {"FFN_gate_prefill512", 512, 4864, 896},
    {"FFN_down_prefill512", 512, 896, 4864},
};

// ============================================================================
// Benchmark Infrastructure
// ============================================================================

struct BenchmarkResult {
    std::string workload_name;
    int m, n, k;
    int mr, nr, k_blocks, unroll_k, prefetch_dist;
    int mc, kc, nc;
    double gflops;
    double time_ms;
    double efficiency_pct;
    bool passed;
};

/**
 * @brief Create Q8_0 tensor with random data
 */
std::shared_ptr<Q8_0Tensor> createRandomQ8Tensor(int rows, int cols, std::mt19937 &rng) {
    std::uniform_int_distribution<int> dist(-127, 127);
    std::uniform_real_distribution<float> scale_dist(0.01f, 1.0f);

    size_t k_blocks = (cols + 31) / 32;
    std::vector<Q8_0Block> blocks(rows * k_blocks);

    for (auto &block : blocks) {
        float scale = scale_dist(rng);
        block.d = fp32_to_fp16(scale);
        for (int i = 0; i < 32; ++i) {
            block.qs[i] = static_cast<int8_t>(dist(rng));
        }
    }

    std::vector<uint8_t> raw_data(blocks.size() * sizeof(Q8_0Block));
    std::memcpy(raw_data.data(), blocks.data(), raw_data.size());

    return std::make_shared<Q8_0Tensor>(
        std::vector<size_t>{static_cast<size_t>(rows), static_cast<size_t>(cols)},
        raw_data);
}

/**
 * @brief Zero-copy block provider
 */
struct SimpleBlockProvider : public Q8_0BlockProvider {
    const Q8_0Block *blocks_;
    size_t k_blocks_, num_rows_;

    SimpleBlockProvider(const Q8_0Block *b, size_t kb, size_t rows)
        : blocks_(b), k_blocks_(kb), num_rows_(rows) {}

    const Q8_0Block *get_q8_block(size_t row_idx, size_t k_block_offset) override {
        return &blocks_[row_idx * k_blocks_ + k_block_offset];
    }

    void warmup_cache(size_t, size_t, size_t, size_t) override {}
    bool is_zero_copy() const override { return true; }
    size_t k_blocks() const override { return k_blocks_; }
    size_t num_rows() const override { return num_rows_; }
};

/**
 * @brief Runtime benchmark executor using kernel registry
 */
BenchmarkResult benchmark_configuration(
    const OpDescriptor &op,
    int mr, int nr, int unroll_k, int prefetch_dist,
    int mc, int kc, int nc,
    std::mt19937 &rng)
{
    BenchmarkResult result;
    result.workload_name = op.name;
    result.m = op.m;
    result.n = op.n;
    result.k = op.k;
    result.mr = mr;
    result.nr = nr;
    result.k_blocks = kc / 32;  // Derived from KC
    result.unroll_k = unroll_k;
    result.prefetch_dist = prefetch_dist;
    result.mc = mc;
    result.kc = kc;
    result.nc = nc;
    result.passed = false;

    try {
        // Look up kernel in registry
        auto &registry = IntegerGemmKernelRegistry::instance();
        auto kernel_func = registry.get_kernel("simd::AVX512VNNITag", mr, nr, unroll_k, prefetch_dist, mc, kc, nc);
        
        if (!kernel_func) {
            // Kernel not registered - skip this configuration
            result.gflops = 0.0;
            result.time_ms = 0.0;
            result.efficiency_pct = 0.0;
            result.passed = false;
            return result;
        }

        // Create test tensors
        auto A_tensor = createRandomQ8Tensor(op.m, op.k, rng);
        auto B_tensor = createRandomQ8Tensor(op.k, op.n, rng);

        // Get raw block pointers via public API
        const Q8_0Block *A_blocks = static_cast<const Q8_0Block *>(A_tensor->get_raw_block_at(0, 0));
        const Q8_0Block *B_blocks = static_cast<const Q8_0Block *>(B_tensor->get_raw_block_at(0, 0));
        
        size_t k_blocks_B = (op.k + 31) / 32;

        SimpleBlockProvider B_provider(B_blocks, k_blocks_B, op.n);

        // Create output Q8_0 tensor for results
        auto C_q8_tensor = createRandomQ8Tensor(op.m, op.n, rng);
        Q8_0Block *C_blocks = const_cast<Q8_0Block *>(
            static_cast<const Q8_0Block *>(C_q8_tensor->get_raw_block_at(0, 0)));

        // Warm-up (3 iterations)
        for (int i = 0; i < 3; ++i) {
            kernel_func(A_blocks, B_provider, C_blocks, op.m, op.n, op.k);
        }

        // Timed run (10 iterations for stable timing)
        constexpr int NUM_ITERS = 10;
        auto start = std::chrono::high_resolution_clock::now();

        for (int i = 0; i < NUM_ITERS; ++i) {
            kernel_func(A_blocks, B_provider, C_blocks, op.m, op.n, op.k);
        }

        auto end = std::chrono::high_resolution_clock::now();
        double elapsed_ms = std::chrono::duration<double, std::milli>(end - start).count();
        double time_per_iter_ms = elapsed_ms / NUM_ITERS;

        // Calculate GFLOPS (2*M*N*K operations)
        double flops = 2.0 * op.m * op.n * op.k;
        double gflops = (flops / (time_per_iter_ms * 1e6));
        double efficiency = (gflops / THEORETICAL_PEAK_GFLOPS) * 100.0;

        result.gflops = gflops;
        result.time_ms = time_per_iter_ms;
        result.efficiency_pct = efficiency;
        result.passed = true;

    } catch (const std::exception &e) {
        // Silently fail - just mark as not passed
        result.gflops = 0.0;
        result.time_ms = 0.0;
        result.efficiency_pct = 0.0;
        result.passed = false;
    }

    return result;
}

// ============================================================================
// Template Dispatch Cascade
// ============================================================================

// Dispatch K_BLOCKS
template <int MR, int NR, int UNROLL_K, int PREFETCH, int MC, int KC, int NC>
BenchmarkResult dispatch_k_blocks(int k_blocks, const OpDescriptor &op, std::mt19937 &rng) {
    switch (k_blocks) {
        case 2: return benchmark_configuration<MR, NR, 2, UNROLL_K, PREFETCH, MC, KC, NC>(op, rng);
        case 4: return benchmark_configuration<MR, NR, 4, UNROLL_K, PREFETCH, MC, KC, NC>(op, rng);
        default: throw std::runtime_error("Invalid K_BLOCKS");
    }
}

// Dispatch UNROLL_K
template <int MR, int NR, int PREFETCH, int MC, int KC, int NC>
BenchmarkResult dispatch_unroll_k(int k_blocks, int unroll_k, const OpDescriptor &op, std::mt19937 &rng) {
    switch (unroll_k) {
        case 1: return dispatch_k_blocks<MR, NR, 1, PREFETCH, MC, KC, NC>(k_blocks, op, rng);
        case 2: return dispatch_k_blocks<MR, NR, 2, PREFETCH, MC, KC, NC>(k_blocks, op, rng);
        case 4: return dispatch_k_blocks<MR, NR, 4, PREFETCH, MC, KC, NC>(k_blocks, op, rng);
        case 8: return dispatch_k_blocks<MR, NR, 8, PREFETCH, MC, KC, NC>(k_blocks, op, rng);
        default: throw std::runtime_error("Invalid UNROLL_K");
    }
}

// Dispatch PREFETCH
template <int MR, int NR, int MC, int KC, int NC>
BenchmarkResult dispatch_prefetch(int k_blocks, int unroll_k, int prefetch, 
                                   const OpDescriptor &op, std::mt19937 &rng) {
    switch (prefetch) {
        case 0: return dispatch_unroll_k<MR, NR, 0, MC, KC, NC>(k_blocks, unroll_k, op, rng);
        case 1: return dispatch_unroll_k<MR, NR, 1, MC, KC, NC>(k_blocks, unroll_k, op, rng);
        case 2: return dispatch_unroll_k<MR, NR, 2, MC, KC, NC>(k_blocks, unroll_k, op, rng);
        case 3: return dispatch_unroll_k<MR, NR, 3, MC, KC, NC>(k_blocks, unroll_k, op, rng);
        default: throw std::runtime_error("Invalid PREFETCH");
    }
}

// Dispatch cache blocking (all 27 combinations: 3×3×3)
template <int MR, int NR>
BenchmarkResult dispatch_cache_blocking(int k_blocks, int unroll_k, int prefetch,
                                        int mc, int kc, int nc,
                                        const OpDescriptor &op, std::mt19937 &rng) {
    // MC dispatch
    if (mc == 128) {
        if (kc == 256) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 128, 256, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 128, 256, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 128, 256, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 512) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 128, 512, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 128, 512, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 128, 512, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 1024) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 128, 1024, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 128, 1024, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 128, 1024, 256>(k_blocks, unroll_k, prefetch, op, rng);
        }
    } else if (mc == 256) {
        if (kc == 256) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 256, 256, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 256, 256, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 256, 256, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 512) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 256, 512, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 256, 512, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 256, 512, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 1024) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 256, 1024, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 256, 1024, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 256, 1024, 256>(k_blocks, unroll_k, prefetch, op, rng);
        }
    } else if (mc == 512) {
        if (kc == 256) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 512, 256, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 512, 256, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 512, 256, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 512) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 512, 512, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 512, 512, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 512, 512, 256>(k_blocks, unroll_k, prefetch, op, rng);
        } else if (kc == 1024) {
            if (nc == 64)  return dispatch_prefetch<MR, NR, 512, 1024, 64>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 128) return dispatch_prefetch<MR, NR, 512, 1024, 128>(k_blocks, unroll_k, prefetch, op, rng);
            if (nc == 256) return dispatch_prefetch<MR, NR, 512, 1024, 256>(k_blocks, unroll_k, prefetch, op, rng);
        }
    }
    
    throw std::runtime_error("Invalid cache blocking params: MC=" + std::to_string(mc) + 
                           " KC=" + std::to_string(kc) + " NC=" + std::to_string(nc));
}

// Dispatch MR
BenchmarkResult dispatch_mr(int mr, int k_blocks, int unroll_k, int prefetch,
                             int mc, int kc, int nc,
                             const OpDescriptor &op, std::mt19937 &rng) {
    constexpr int NR = 32;
    switch (mr) {
        case 4:  return dispatch_cache_blocking<4, NR>(k_blocks, unroll_k, prefetch, mc, kc, nc, op, rng);
        case 8:  return dispatch_cache_blocking<8, NR>(k_blocks, unroll_k, prefetch, mc, kc, nc, op, rng);
        case 16: return dispatch_cache_blocking<16, NR>(k_blocks, unroll_k, prefetch, mc, kc, nc, op, rng);
        case 32: return dispatch_cache_blocking<32, NR>(k_blocks, unroll_k, prefetch, mc, kc, nc, op, rng);
        default: throw std::runtime_error("Invalid MR");
    }
}

// ============================================================================
// Test Cases
// ============================================================================

/**
 * @brief Full sweep: All configs × all workloads
 * Configuration space: 4 MR × 2 K_BLOCKS × 4 UNROLL_K × 4 PREFETCH × 27 CACHE_BLOCKING = 3,456 configs/workload
 * Total: 3,456 × 12 workloads = 41,472 configs
 * Expected runtime: 2-4 hours
 * Expected output: ~40,000+ CSV rows in integer_gemm_sweep_full.csv
 */
TEST(IntegerGEMM_FullSweep, AllConfigsAllWorkloads) {
    std::mt19937 rng(42);
    
    // Output CSV file
    std::ofstream csv_file("integer_gemm_sweep_full.csv");
    ASSERT_TRUE(csv_file.is_open()) << "Failed to open output file";
    
    // CSV header
    csv_file << "m,n,k,mr,nr,k_blocks,unroll_k,prefetch_dist,mc,kc,nc,gflops,time_ms,efficiency_pct\n";
    
    size_t total_configs = 0;
    size_t passed_configs = 0;
    
    for (const auto &op : ALL_WORKLOADS) {
        for (int mr : MR_VALUES) {
            for (int k_blocks : K_BLOCKS_VALUES) {
                for (int unroll_k : UNROLL_K_VALUES) {
                    for (int prefetch : PREFETCH_DIST_VALUES) {
                        // Full cache blocking sweep: 3×3×3 = 27 combinations
                        for (int mc : MC_VALUES) {
                            for (int kc : KC_VALUES) {
                                for (int nc : NC_VALUES) {
                                    total_configs++;
                                    
                                    auto result = dispatch_mr(mr, k_blocks, unroll_k, prefetch,
                                                             mc, kc, nc, op, rng);
                                    
                                    if (result.passed) {
                                        passed_configs++;
                                        csv_file << result.m << "," << result.n << "," << result.k << ","
                                                 << result.mr << "," << result.nr << "," << result.k_blocks << ","
                                                 << result.unroll_k << "," << result.prefetch_dist << ","
                                                 << result.mc << "," << result.kc << "," << result.nc << ","
                                                 << std::fixed << std::setprecision(2)
                                                 << result.gflops << "," << result.time_ms << "," 
                                                 << result.efficiency_pct << "\n";
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    
    csv_file.close();
    std::cout << "Sweep complete: " << passed_configs << " / " << total_configs << " configs passed\n";
    std::cout << "Results written to: integer_gemm_sweep_full.csv\n";
}

/**
 * @brief Single workload sweep: All configs on M=1 decode workload
 * Configuration space: 3,456 configs
 * Expected runtime: 30-60 minutes
 * Expected output: ~3,400 CSV rows in integer_gemm_sweep_single_token.csv
 */
TEST(IntegerGEMM_FullSweep, AllConfigsSingleToken) {
    std::mt19937 rng(42);
    
    // Use FFN_gate decode (widest matrix)
    OpDescriptor op = {"FFN_gate_decode", 1, 4864, 896};
    
    // Output CSV file
    std::ofstream csv_file("integer_gemm_sweep_single_token.csv");
    ASSERT_TRUE(csv_file.is_open()) << "Failed to open output file";
    
    // CSV header
    csv_file << "m,n,k,mr,nr,k_blocks,unroll_k,prefetch_dist,mc,kc,nc,gflops,time_ms,efficiency_pct\n";
    
    size_t total_configs = 0;
    size_t passed_configs = 0;
    
    for (int mr : MR_VALUES) {
        for (int k_blocks : K_BLOCKS_VALUES) {
            for (int unroll_k : UNROLL_K_VALUES) {
                for (int prefetch : PREFETCH_DIST_VALUES) {
                    // Full cache blocking sweep: 3×3×3 = 27 combinations
                    for (int mc : MC_VALUES) {
                        for (int kc : KC_VALUES) {
                            for (int nc : NC_VALUES) {
                                total_configs++;
                                
                                auto result = dispatch_mr(mr, k_blocks, unroll_k, prefetch,
                                                         mc, kc, nc, op, rng);
                                
                                if (result.passed) {
                                    passed_configs++;
                                    csv_file << result.m << "," << result.n << "," << result.k << ","
                                             << result.mr << "," << result.nr << "," << result.k_blocks << ","
                                             << result.unroll_k << "," << result.prefetch_dist << ","
                                             << result.mc << "," << result.kc << "," << result.nc << ","
                                             << std::fixed << std::setprecision(2)
                                             << result.gflops << "," << result.time_ms << "," 
                                             << result.efficiency_pct << "\n";
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    
    csv_file.close();
    std::cout << "Sweep complete: " << passed_configs << " / " << total_configs << " configs passed\n";
    std::cout << "Results written to: integer_gemm_sweep_single_token.csv\n";
}

// ============================================================================
// Single Configuration Tests (for perf profiling)
// ============================================================================

/**
 * @brief Run a single specific configuration
 * Used by perf profiling script to measure hardware counters
 * 
 * Test name encodes all parameters:
 * SingleConfig_M<m>_N<n>_K<k>_MR<mr>_NR<nr>_KB<k_blocks>_U<unroll>_P<prefetch>_MC<mc>_KC<kc>_NC<nc>
 */
#define SINGLE_CONFIG_TEST(M, N, K, MR, NR, KB, U, P, MC, KC, NC) \
TEST(IntegerGEMM_FullSweep, SingleConfig_M##M##_N##N##_K##K##_MR##MR##_NR##NR##_KB##KB##_U##U##_P##P##_MC##MC##_KC##KC##_NC##NC) { \
    std::mt19937 rng(42); \
    OpDescriptor op = {"single_config", M, N, K}; \
    \
    auto result = benchmark_configuration<MR, NR, KB, U, P, MC, KC, NC>(op, rng); \
    \
    std::cout << "m,n,k,mr,nr,k_blocks,unroll_k,prefetch_dist,mc,kc,nc,gflops,time_ms,efficiency_pct\n"; \
    if (result.passed) { \
        std::cout << result.m << "," << result.n << "," << result.k << "," \
                 << result.mr << "," << result.nr << "," << result.k_blocks << "," \
                 << result.unroll_k << "," << result.prefetch_dist << "," \
                 << result.mc << "," << result.kc << "," << result.nc << "," \
                 << std::fixed << std::setprecision(2) \
                 << result.gflops << "," << result.time_ms << "," \
                 << result.efficiency_pct << "\n"; \
    } \
    ASSERT_TRUE(result.passed); \
}

// Register some common single-config tests (perf script can call any via --gtest_filter)
// These match the top/bottom performers from the sweep

// Example: Decode workload with MR=8
SINGLE_CONFIG_TEST(1, 4864, 896, 8, 32, 4, 4, 2, 256, 512, 128)

// Example: Prefill-512 workload with MR=8
SINGLE_CONFIG_TEST(512, 896, 896, 8, 32, 4, 4, 2, 256, 512, 128)

// Example: Prefill-512 workload with MR=4 (best performer)
SINGLE_CONFIG_TEST(512, 4864, 896, 4, 32, 4, 2, 2, 256, 512, 128)

// Example: Poor performer (MR=32)
SINGLE_CONFIG_TEST(512, 896, 896, 32, 32, 4, 4, 2, 256, 512, 128)

int main(int argc, char **argv) {
    ::testing::InitGoogleTest(&argc, argv);
    return RUN_ALL_TESTS();
}
