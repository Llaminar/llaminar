/**
 * @file Perf__IntegerGEMM_TileSweep.cpp
 * @brief Comprehensive tile size parameter sweep for Integer GEMM kernels
 *
 * Tests all Qwen 0.5B workloads across a grid of tile configurations to find
 * optimal parameters for each operation size.
 *
 * Parameter Space:
 * - MR: Micro-kernel M dimension (4, 8, 16, 32)
 * - UNROLL_K: K-loop unroll factor (1, 2, 4, 8)
 * - PREFETCH_DIST: Prefetch distance (0, 1, 2, 3)
 * - MC: M cache block (128, 256, 512, 1024)
 * - KC: K cache block (256, 512, 1024, 2048)
 * - NC: N cache block (64, 128, 256, 512)
 *
 * Output: CSV format for analysis
 * m,n,k,MR,NR,K_BLOCKS,UNROLL_K,PREFETCH,MC,KC,NC,GFLOPS,Time_ms,Efficiency
 *
 * @author David Sanftenberg
 * @date November 12, 2025
 */

#include <gtest/gtest.h>
#include <chrono>
#include <memory>
#include <vector>
#include <iostream>
#include <iomanip>
#include <fstream>
#include <random>
#include <cmath>

#include "kernels/cpu/gemm/IntegerGemmKernelTemplateV2.h"
#include "kernels/cpu/gemm/GemmWeightCache.h"
#include "tensors/Tensors.h"
#include "tensors/BlockStructures.h"

using namespace llaminar2;
using namespace llaminar2::kernels;
using namespace llaminar2::kernels::gemm;
using namespace llaminar2::kernels::simd;

// ============================================================================
// Configuration Space
// ============================================================================

// Tile size parameters to sweep
const std::vector<int> MR_VALUES = {4, 8, 16, 32};
const std::vector<int> UNROLL_K_VALUES = {1, 2, 4, 8};
const std::vector<int> PREFETCH_DIST_VALUES = {0, 1, 2, 3};
const std::vector<int> MC_VALUES = {128, 256, 512, 1024};
const std::vector<int> KC_VALUES = {256, 512, 1024, 2048};
const std::vector<int> NC_VALUES = {64, 128, 256, 512};
const std::vector<int> K_BLOCKS_VALUES = {2, 4}; // 64-byte and 128-byte modes

// Fixed parameters
constexpr int NR = 32; // Must be 32 for Q8_0 block alignment
using ISA = AVX512VNNITag;

// ============================================================================
// Test Workloads (Qwen 0.5B operations)
// ============================================================================

struct OpDescriptor
{
    std::string name;
    int m, n, k;
};

const std::vector<OpDescriptor> WORKLOADS = {
    // Single-token decode (critical for latency)
    {"Q_proj (decode)", 1, 896, 896},
    {"FFN_gate (decode)", 1, 4864, 896},
    {"FFN_down (decode)", 1, 896, 4864},
    
    // Prefill workloads (batch size × seq_len as M dimension)
    {"Q_proj (prefill-32)", 32, 896, 896},
    {"FFN_gate (prefill-32)", 32, 4864, 896},
    {"FFN_down (prefill-32)", 32, 896, 4864},
    
    {"Q_proj (prefill-128)", 128, 896, 896},
    {"FFN_gate (prefill-128)", 128, 4864, 896},
    {"FFN_down (prefill-128)", 128, 896, 4864},
    
    {"Q_proj (prefill-512)", 512, 896, 896},
    {"FFN_gate (prefill-512)", 512, 4864, 896},
    {"FFN_down (prefill-512)", 512, 896, 4864},
};

// ============================================================================
// Benchmark Infrastructure
// ============================================================================

struct BenchmarkResult
{
    std::string name;
    int m, n, k;
    int MR, NR, K_BLOCKS, UNROLL_K, PREFETCH_DIST;
    int MC, KC, NC;
    double gflops;
    double time_ms;
    double efficiency_pct;
    bool passed;
};

/**
 * @brief Create Q8_0 tensor with random data
 */
std::shared_ptr<Q8_0Tensor> createRandomQ8Tensor(int rows, int cols, std::mt19937 &rng)
{
    std::uniform_int_distribution<int> dist(-127, 127);
    std::uniform_real_distribution<float> scale_dist(0.01f, 1.0f);

    size_t k_blocks = (cols + 31) / 32;
    std::vector<Q8_0Block> blocks(rows * k_blocks);

    for (auto &block : blocks)
    {
        float scale = scale_dist(rng);
        block.d = fp32_to_fp16(scale);
        for (int i = 0; i < 32; ++i)
        {
            block.qs[i] = static_cast<int8_t>(dist(rng));
        }
    }

    std::vector<uint8_t> raw_data(blocks.size() * sizeof(Q8_0Block));
    std::memcpy(raw_data.data(), blocks.data(), raw_data.size());

    return std::make_shared<Q8_0Tensor>(
        std::vector<size_t>{static_cast<size_t>(rows), static_cast<size_t>(cols)},
        raw_data);
}

/**
 * @brief Zero-copy block provider
 */
struct SimpleBlockProvider : public Q8_0BlockProvider
{
    const Q8_0Block *blocks_;
    size_t k_blocks_, num_rows_;

    SimpleBlockProvider(const Q8_0Block *b, size_t kb, size_t rows)
        : blocks_(b), k_blocks_(kb), num_rows_(rows) {}

    const Q8_0Block *get_q8_block(size_t row_idx, size_t k_block_offset) override
    {
        return &blocks_[row_idx * k_blocks_ + k_block_offset];
    }

    void warmup_cache(size_t, size_t, size_t, size_t) override {}
    bool is_zero_copy() const override { return true; }
    size_t k_blocks() const override { return k_blocks_; }
    size_t num_rows() const override { return num_rows_; }
};

/**
 * @brief Benchmark a specific kernel configuration
 */
template <int MR, int NR, int K_BLOCKS_PER_ITER, int UNROLL_K, int PREFETCH_DIST, int MC, int KC, int NC>
BenchmarkResult benchmark_configuration(const OpDescriptor &op, std::mt19937 &rng)
{
    BenchmarkResult result;
    result.name = op.name;
    result.m = op.m;
    result.n = op.n;
    result.k = op.k;
    result.MR = MR;
    result.NR = NR;
    result.K_BLOCKS = K_BLOCKS_PER_ITER;
    result.UNROLL_K = UNROLL_K;
    result.PREFETCH_DIST = PREFETCH_DIST;
    result.MC = MC;
    result.KC = KC;
    result.NC = NC;
    result.passed = false;

    using KernelType = IntegerGemmKernelV2<ISA, MR, NR, K_BLOCKS_PER_ITER, UNROLL_K, PREFETCH_DIST, MC, KC, NC>;

    try
    {
        // Create tensors
        auto A = createRandomQ8Tensor(op.m, op.k, rng);
        auto B = createRandomQ8Tensor(op.k, op.n, rng);
        auto C = createRandomQ8Tensor(op.m, op.n, rng);

        // Get raw block pointers
        const Q8_0Block *A_blocks = static_cast<const Q8_0Block *>(A->get_raw_block_at(0, 0));
        const Q8_0Block *B_blocks = static_cast<const Q8_0Block *>(B->get_raw_block_at(0, 0));
        Q8_0Block *C_blocks = const_cast<Q8_0Block *>(static_cast<const Q8_0Block *>(C->get_raw_block_at(0, 0)));

        size_t a_k_blocks = (op.k + 31) / 32;
        size_t b_k_blocks = (op.n + 31) / 32;

        // Create weight provider
        SimpleBlockProvider B_provider(B_blocks, a_k_blocks, op.k);

        // Warmup (3 iterations)
        for (int i = 0; i < 3; ++i)
        {
            KernelType::multiply(A_blocks, B_provider, C_blocks, op.m, op.n, op.k);
        }

        // Benchmark (10 iterations for stable timing)
        constexpr int NUM_ITERS = 10;
        auto start = std::chrono::high_resolution_clock::now();
        
        for (int i = 0; i < NUM_ITERS; ++i)
        {
            KernelType::multiply(A_blocks, B_provider, C_blocks, op.m, op.n, op.k);
        }
        
        auto end = std::chrono::high_resolution_clock::now();
        double elapsed_ms = std::chrono::duration<double, std::milli>(end - start).count();

        // Calculate metrics
        double ops_per_iter = 2.0 * op.m * op.n * op.k; // multiply-add counts as 2 ops
        double total_ops = ops_per_iter * NUM_ITERS;
        double avg_ms = elapsed_ms / NUM_ITERS;
        double gflops = (ops_per_iter / (avg_ms * 1e6));

        // Theoretical peak (rough estimate: 28 cores × 2 FMA units × base freq ~2.5 GHz × 16 ops/cycle)
        // For integer ops with VNNI: ~28 × 2.5 × 64 = ~4500 GFLOPS theoretical
        constexpr double THEORETICAL_PEAK_GFLOPS = 358.4; // More realistic: single-socket bound
        double efficiency_pct = (gflops / THEORETICAL_PEAK_GFLOPS) * 100.0;

        result.gflops = gflops;
        result.time_ms = avg_ms;
        result.efficiency_pct = efficiency_pct;
        result.passed = true;
    }
    catch (const std::exception &e)
    {
        result.gflops = 0.0;
        result.time_ms = 0.0;
        result.efficiency_pct = 0.0;
        result.passed = false;
    }

    return result;
}

// ============================================================================
// Dispatch Templates (for runtime parameter selection)
// ============================================================================

/**
 * @brief Dispatch based on K_BLOCKS_PER_ITER
 */
template <int MR, int UNROLL_K, int PREFETCH_DIST, int MC, int KC, int NC>
BenchmarkResult dispatch_k_blocks(int k_blocks, const OpDescriptor &op, std::mt19937 &rng)
{
    if (k_blocks == 4)
    {
        return benchmark_configuration<MR, 32, 4, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(op, rng);
    }
    else // k_blocks == 2
    {
        return benchmark_configuration<MR, 32, 2, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(op, rng);
    }
}

/**
 * @brief Dispatch based on MR
 */
template <int UNROLL_K, int PREFETCH_DIST, int MC, int KC, int NC>
BenchmarkResult dispatch_mr(int mr, int k_blocks, const OpDescriptor &op, std::mt19937 &rng)
{
    switch (mr)
    {
    case 4:
        return dispatch_k_blocks<4, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(k_blocks, op, rng);
    case 8:
        return dispatch_k_blocks<8, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(k_blocks, op, rng);
    case 16:
        return dispatch_k_blocks<16, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(k_blocks, op, rng);
    case 32:
        return dispatch_k_blocks<32, UNROLL_K, PREFETCH_DIST, MC, KC, NC>(k_blocks, op, rng);
    default:
        BenchmarkResult fail;
        fail.passed = false;
        return fail;
    }
}

/**
 * @brief Dispatch based on UNROLL_K
 */
template <int PREFETCH_DIST, int MC, int KC, int NC>
BenchmarkResult dispatch_unroll_k(int mr, int k_blocks, int unroll_k, const OpDescriptor &op, std::mt19937 &rng)
{
    switch (unroll_k)
    {
    case 1:
        return dispatch_mr<1, PREFETCH_DIST, MC, KC, NC>(mr, k_blocks, op, rng);
    case 2:
        return dispatch_mr<2, PREFETCH_DIST, MC, KC, NC>(mr, k_blocks, op, rng);
    case 4:
        return dispatch_mr<4, PREFETCH_DIST, MC, KC, NC>(mr, k_blocks, op, rng);
    case 8:
        return dispatch_mr<8, PREFETCH_DIST, MC, KC, NC>(mr, k_blocks, op, rng);
    default:
        BenchmarkResult fail;
        fail.passed = false;
        return fail;
    }
}

/**
 * @brief Dispatch based on PREFETCH_DIST
 */
template <int MC, int KC, int NC>
BenchmarkResult dispatch_prefetch(int mr, int k_blocks, int unroll_k, int prefetch, const OpDescriptor &op, std::mt19937 &rng)
{
    switch (prefetch)
    {
    case 0:
        return dispatch_unroll_k<0, MC, KC, NC>(mr, k_blocks, unroll_k, op, rng);
    case 1:
        return dispatch_unroll_k<1, MC, KC, NC>(mr, k_blocks, unroll_k, op, rng);
    case 2:
        return dispatch_unroll_k<2, MC, KC, NC>(mr, k_blocks, unroll_k, op, rng);
    case 3:
        return dispatch_unroll_k<3, MC, KC, NC>(mr, k_blocks, unroll_k, op, rng);
    default:
        BenchmarkResult fail;
        fail.passed = false;
        return fail;
    }
}

/**
 * @brief Top-level dispatch for all parameters
 */
BenchmarkResult dispatch_all_params(
    int mr, int k_blocks, int unroll_k, int prefetch, int mc, int kc, int nc,
    const OpDescriptor &op, std::mt19937 &rng)
{
    // For now, we'll test a subset of cache blocking parameters
    // Full sweep would be (4 × 2 × 4 × 4 × 4 × 4 × 4) = 8192 configs
    // We'll test a practical subset: fixed MC=256, KC=512, NC=128 (current defaults)
    
    if (mc == 256 && kc == 512 && nc == 128)
    {
        return dispatch_prefetch<256, 512, 128>(mr, k_blocks, unroll_k, prefetch, op, rng);
    }
    else if (mc == 512 && kc == 1024 && nc == 256)
    {
        return dispatch_prefetch<512, 1024, 256>(mr, k_blocks, unroll_k, prefetch, op, rng);
    }
    else if (mc == 128 && kc == 256 && nc == 64)
    {
        return dispatch_prefetch<128, 256, 64>(mr, k_blocks, unroll_k, prefetch, op, rng);
    }
    else
    {
        BenchmarkResult fail;
        fail.passed = false;
        return fail;
    }
}

// ============================================================================
// Test Cases
// ============================================================================

/**
 * @brief Quick sweep: Test key parameters on one representative workload
 */
TEST(IntegerGEMM_TileSweep, QuickSweep)
{
    std::mt19937 rng(42);
    
    // Test one representative workload (prefill-512, largest compute)
    OpDescriptor op = {"FFN_gate (prefill-512)", 512, 4864, 896};
    
    std::cout << "\n╔══════════════════════════════════════════════════════════════════════╗\n";
    std::cout << "║ QUICK PARAMETER SWEEP - " << op.name << " (" << op.m << "×" << op.n << "×" << op.k << ")\n";
    std::cout << "╚══════════════════════════════════════════════════════════════════════╝\n\n";
    
    std::cout << "Testing MR × K_BLOCKS × UNROLL_K combinations...\n\n";
    
    // CSV header
    std::cout << "MR,K_BLOCKS,UNROLL_K,PREFETCH,MC,KC,NC,GFLOPS,Time_ms,Eff%\n";
    
    double best_gflops = 0.0;
    BenchmarkResult best_result;
    
    // Test subset of parameter space
    for (int mr : {4, 8, 16, 32})
    {
        for (int k_blocks : {2, 4})
        {
            for (int unroll_k : {1, 2, 4, 8})
            {
                for (int prefetch : {0, 2})
                {
                    auto result = dispatch_all_params(mr, k_blocks, unroll_k, prefetch, 256, 512, 128, op, rng);
                    
                    if (result.passed)
                    {
                        std::cout << mr << "," << k_blocks << "," << unroll_k << "," << prefetch << ","
                                  << "256,512,128," << std::fixed << std::setprecision(2)
                                  << result.gflops << "," << result.time_ms << "," << result.efficiency_pct << "\n";
                        
                        if (result.gflops > best_gflops)
                        {
                            best_gflops = result.gflops;
                            best_result = result;
                        }
                    }
                }
            }
        }
    }
    
    std::cout << "\n╔══════════════════════════════════════════════════════════════════════╗\n";
    std::cout << "║ BEST CONFIGURATION\n";
    std::cout << "╠══════════════════════════════════════════════════════════════════════╣\n";
    std::cout << "║ MR=" << best_result.MR << " K_BLOCKS=" << best_result.K_BLOCKS 
              << " UNROLL_K=" << best_result.UNROLL_K << " PREFETCH=" << best_result.PREFETCH_DIST << "\n";
    std::cout << "║ MC=" << best_result.MC << " KC=" << best_result.KC << " NC=" << best_result.NC << "\n";
    std::cout << "║ Performance: " << std::fixed << std::setprecision(2) << best_result.gflops 
              << " GFLOPS (" << best_result.efficiency_pct << "% efficiency)\n";
    std::cout << "╚══════════════════════════════════════════════════════════════════════╝\n";
}

/**
 * @brief Full sweep: Test all workloads with best parameters from quick sweep
 */
TEST(IntegerGEMM_TileSweep, FullWorkloadSweep)
{
    std::mt19937 rng(42);
    
    std::cout << "\n╔══════════════════════════════════════════════════════════════════════╗\n";
    std::cout << "║ FULL WORKLOAD SWEEP - Testing All Qwen 0.5B Operations\n";
    std::cout << "╚══════════════════════════════════════════════════════════════════════╝\n\n";
    
    // CSV header
    std::cout << "Workload,M,N,K,MR,K_BLOCKS,UNROLL_K,PREFETCH,MC,KC,NC,GFLOPS,Time_ms,Eff%\n";
    
    // Test each workload with a grid of configurations
    for (const auto &op : WORKLOADS)
    {
        double best_gflops = 0.0;
        BenchmarkResult best_result;
        
        // For each workload, test key parameter combinations
        for (int mr : {8, 16, 32})
        {
            for (int k_blocks : {2, 4})
            {
                for (int unroll_k : {2, 4, 8})
                {
                    int prefetch = 2; // Fixed for now
                    auto result = dispatch_all_params(mr, k_blocks, unroll_k, prefetch, 256, 512, 128, op, rng);
                    
                    if (result.passed)
                    {
                        std::cout << "\"" << result.name << "\"," 
                                  << result.m << "," << result.n << "," << result.k << ","
                                  << result.MR << "," << result.K_BLOCKS << "," << result.UNROLL_K << ","
                                  << result.PREFETCH_DIST << "," << result.MC << "," << result.KC << "," << result.NC << ","
                                  << std::fixed << std::setprecision(2)
                                  << result.gflops << "," << result.time_ms << "," << result.efficiency_pct << "\n";
                        
                        if (result.gflops > best_gflops)
                        {
                            best_gflops = result.gflops;
                            best_result = result;
                        }
                    }
                }
            }
        }
        
        // Print best for this workload
        std::cerr << "BEST for " << op.name << ": MR=" << best_result.MR 
                  << " K_BLOCKS=" << best_result.K_BLOCKS << " UNROLL_K=" << best_result.UNROLL_K
                  << " → " << best_result.gflops << " GFLOPS\n";
    }
}

int main(int argc, char **argv)
{
    ::testing::InitGoogleTest(&argc, argv);
    return RUN_ALL_TESTS();
}
