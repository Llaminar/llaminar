#!/bin/bash
# Pre-commit hook template for Llaminar project
# 
# Installation:
#   cp .githooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# This hook runs unit tests before allowing a commit.
# Override with: git commit --no-verify

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit unit tests...${NC}"
echo ""

# Determine which build directory to use
if [ -d "build_v2_coverage" ]; then
    BUILD_DIR="build_v2_coverage"
elif [ -d "build_v2" ]; then
    BUILD_DIR="build_v2"
elif [ -d "build" ]; then
    BUILD_DIR="build"
else
    echo -e "${RED}❌ No build directory found. Please build the project first.${NC}"
    echo -e "${YELLOW}Hint: Run 'cmake -B build_v2 -S src/v2' and 'cmake --build build_v2'${NC}"
    exit 1
fi

# Run unit tests using CTest
echo -e "${YELLOW}Running V2 unit tests (tests/v2/unit/)...${NC}"
echo ""

# Run CTest with unit test filter
# Filter: ^V2_Unit_ matches all unit tests (excludes Integration, E2E, Performance)
set +e
ctest --test-dir "$BUILD_DIR" -R "^V2_Unit_" --output-on-failure
EXIT_CODE=$?
set -e

echo ""
echo "================================================"
if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ All unit tests passed!${NC}"
    echo -e "${GREEN}Proceeding with commit...${NC}"
    exit 0
else
    echo -e "${RED}❌ Some unit tests failed.${NC}"
    echo ""
    echo -e "${YELLOW}Commit blocked. Fix failing tests or use:${NC}"
    echo -e "${YELLOW}  git commit --no-verify${NC}"
    echo -e "${YELLOW}to skip this check.${NC}"
    exit 1
fi
